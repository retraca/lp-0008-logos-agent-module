[0.000, "o", "\u001b[1m   Use case 3 — a paid skill marketplace, no human in the loop\u001b[0m\r\n"]
[3.610, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 14 · A peer offers a skill for a price   \u001b[2mF7 · F8\u001b[0m\r\n\r\n\r\n"]
[2.277, "o", "\u001b[1;33m   a second agent publishes its A2A card\u001b[0m\r\n\r\n"]
[2.782, "o", "\u001b[2m       skill  compute.run     price  5 LEZ\u001b[0m\r\n"]
[0.476, "o", "\u001b[2m       id     Private/HE6WGdF23Tf3oCrCJ4mcBM3NnZ…\u001b[0m\r\n"]
[0.504, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Discoverable over Logos Messaging, with a price.\u001b[0m\r\n"]
[2.695, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 15 · The agent hires it and pays, by itself   \u001b[2mF8\u001b[0m\r\n"]
[0.000, "o", "\r\n\r\n"]
[2.308, "o", "\u001b[1;33m   5 is under the 50 limit, so it pays with no approval\u001b[0m\r\n\r\n"]
[2.853, "o", "\u001b[2m       before:  agent 60 LEZ    peer B 0 LEZ\u001b[0m\r\n"]
[0.489, "o", "\r\n"]
[0.000, "o", "   \u001b[1;32m\u001b[1m$\u001b[0m \u001b[1mlogoscore call agent_module agent_task <B-card> compute.run\u001b[0m\r\n"]
[2.037, "o", "     task task_185088671802583_0 · price 5 · status submitted\r\n"]
[4.063, "o", "     → transfer proof generated\r\n     → transfer proof generated\r\n"]
[22.218, "o", "\u001b[2m       after:   agent \u001b[1;32m55\u001b[0m\u001b[0;37m LEZ    peer B \u001b[1;32m5\u001b[0m\u001b[0;37m LEZ\u001b[0m\r\n"]
[0.507, "o", "\r\n\u001b[1;32m   ✓ Settled. −5 from its own funds, +5 to the peer. No human, no processor.\u001b[0m\r\n"]
