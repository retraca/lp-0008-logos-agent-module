[1.006, "o", "\u001b[0;36m$ logoscore status\u001b[0m\r\n"]
[0.661, "o", "   loaded 6 / crashed 0\r\n   • storage_module loaded\r\n   • chat_module loaded\r\n   • capability_module loaded\r\n   • lez_wallet_module loaded\r\n   • delivery_module loaded\r\n   • agent_module loaded\r\n"]
[1.512, "o", "\r\n\u001b[1;34m══════════════════════════════════════════════════════════════\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  2. AGENT IDENTITY + ALL SKILLS (F6) + A2A-compatible Agent Card (F7)\u001b[0m\r\n"]
