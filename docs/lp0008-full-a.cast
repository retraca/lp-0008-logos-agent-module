[0.666, "o", "    21 skills: storage.upload, storage.download, storage.list, storage.share, messaging.send, messaging.join, messaging.create_group, wallet.balance, wallet.send, wallet.history, program.query, program.call, program.deploy, agent.card, agent.discover, agent.task, agent.subscribe, agent.cancel, meta.skills, meta.status, meta.configure\r\n"]
[0.004, "o", "\u001b[0;36m$ agent_module agent_card  — A2A schema (agentInterfaces, capabilities, skills, x-lez-identity)\u001b[0m\r\n"]
[0.660, "o", "   A2A fields: agentInterfaces, capabilities, name, skills, version\r\n"]
[0.000, "o", "   x-lez ext: True\r\n"]
[1.512, "o", "\r\n"]
