[0.009, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.009, "o", "\u001b[1m  LP-0008  ·  autonomous AI agent module for Logos Core\u001b[0m\r\n\u001b[2m  A native Logos Core module: the agent holds its own shielded LEZ wallet,\u001b[0m\r\n\u001b[2m  stores files on Logos Storage, finds other agents over Logos Messaging,\u001b[0m\r\n\u001b[2m  and pays them within limits its owner sets. Real proofs, RISC0_DEV_MODE=0.\u001b[0m\r\n"]
[3.012, "o", "\r\n\u001b[1;36m\u001b[1m  the run, end to end\u001b[0m\r\n\u001b[2m    deploy the agent · its wallet, skills, and A2A card · fund it\u001b[0m\r\n\u001b[2m    a storage file-vault round-trip · two agents discover and transact\u001b[0m\r\n\u001b[2m    the spending gate · restart-recovery · skill isolation\u001b[0m\r\n"]
[9.177, "o", "\r\n\u001b[1;36m\u001b[1m  1.  the local LEZ chain\u001b[0m\r\n\u001b[2m  # a standalone sequencer with real proving; genesis is the faucet with 10000 test LEZ.\u001b[0m\r\n\u001b[1;32m  $ \u001b[0m\u001b[1ms"]
