+++ /private/tmp/logos-delivery-patched/logos_delivery/messaging/delivery_service/send_service/lightpush_processor.nim	2026-06-17 11:35:20
@@ -4,21 +4,27 @@
 import
   logos_delivery/waku/node/peer_manager,
   logos_delivery/waku/waku_core,
-  logos_delivery/waku/waku_lightpush/[common, client, rpc]
+  logos_delivery/waku/waku_lightpush_legacy/[common, client]
 
 import ./[delivery_task, send_processor]
 
 logScope:
   topics = "send service lightpush processor"
 
+# NOTE: Uses the legacy lightpush codec (/vac/waku/lightpush/2.0.0-beta1) because
+# nwaku v0.24-v0.33 only register the legacy wire handler despite 3.0.0 being in
+# their identify advertisement. The modern client (3.0.0) fails multistream-select
+# against all tested nwaku relay versions. This patch can be reverted once nwaku
+# relay nodes consistently expose /vac/waku/lightpush/3.0.0 as an actual handler.
+
 type LightpushSendProcessor* = ref object of BaseSendProcessor
   peerManager: PeerManager
-  lightpushClient: WakuLightPushClient
+  lightpushClient: WakuLegacyLightPushClient
 
 proc new*(
     T: typedesc[LightpushSendProcessor],
     peerManager: PeerManager,
-    lightpushClient: WakuLightPushClient,
+    lightpushClient: WakuLegacyLightPushClient,
     brokerCtx: BrokerContext,
 ): T =
   return
@@ -27,7 +33,7 @@
 proc isLightpushPeerAvailable(
     self: LightpushSendProcessor, pubsubTopic: PubsubTopic
 ): bool =
-  return self.peerManager.selectPeer(WakuLightPushCodec, some(pubsubTopic)).isSome()
+  return self.peerManager.selectPeer(WakuLegacyLightPushCodec, some(pubsubTopic)).isSome()
 
