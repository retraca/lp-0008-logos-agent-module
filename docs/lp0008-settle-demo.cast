[0.013, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m   Use case 3 — a paid skill marketplace, no human in the loop\u001b[0m\r\n"]
[3.507, "o", "\r\n\r\n\r\n\u001b[1;36m▌ 14 · A peer offers a skill for a price   \u001b[2mF7 · F8\u001b[0m\r\n\r\n\r\n"]
[3.009, "o", "\u001b[1;33m   a second agent publishes its A2A card\u001b[0m\r\n\r\n\r\n"]
[3.578, "o", "\u001b[0;37m     skill  compute.run     price  5 LEZ\u001b[0m\r\n"]
[0.607, "o", "\u001b[0;37m     id     Private/HyVtdhqs6jLapknfsYNkkjS7jZ…\u001b[0m\r\n"]
[0.608, "o", "\r\n"]
[0.001, "o", "\u001b[1;32m   ✓ Discoverable over Logos Messaging, with a price.\u001b[0m\r\n"]
[3.509, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 15 · The agent hires it and pays, by itself   \u001b[2mF8\u001b[0m\r\n"]
[0.000, "o", "\r\n\r\n"]
[3.010, "o", "\u001b[1;33m   5 is under the 50 limit, so it pays with no approval\u001b[0m\r\n\r\n\r\n"]
[3.580, "o", "\u001b[0;37m     before:  agent 65 LEZ    peer B 0 LEZ\u001b[0m\r\n"]
[0.604, "o", "\r\n"]
[0.000, "o", "\u001b[1m   $ logoscore call agent_module agent_task <B-card> compute.run\u001b[0m\r\n"]
[2.570, "o", "     task task_170205569987458_0 · price 5 · status submitted\r\n"]
[4.019, "o", "     → transfer proof generated\r\n     → transfer proof generated\r\n"]
[12.111, "o", "\u001b[0;37m     after:   agent \u001b[1;32m60\u001b[0m\u001b[0;37m LEZ    peer B \u001b[1;32m5\u001b[0m\u001b[0;37m LEZ\u001b[0m\r\n"]
[0.607, "o", "\r\n\u001b[1;32m   ✓ Settled. −5 from its own funds, +5 to the peer. No human, no processor.\u001b[0m\r\n"]
[3.510, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 16 · Above the cap, it asks first   \u001b[2mF5\u001b[0m\r\n\r\n\r\n"]
[3.008, "o", "\u001b[1;33m   at 80, over the 50 limit, it holds for the owner\u001b[0m\r\n\r\n\r\n"]
[3.508, "o", "\u001b[1m   $ logoscore call agent_module agent_task <card price=80>\u001b[0m\r\n"]
[2.510, "o", "\u001b[0;37m     80 > 50  →  pending_approval, not sent\u001b[0m\r\n"]
[0.606, "o", "\r\n\u001b[1;32m   ✓ Autonomy under the cap, owner approval above it.\u001b[0m\r\n"]
[3.511, "o", "\r\n\r\n\r\n"]
