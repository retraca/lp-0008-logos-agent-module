[0.018, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1m   LP-0008 — an autonomous AI agent on Logos\u001b[0m\r\n\r\n\u001b[2m   every command is real and runs live · RISC0_DEV_MODE=0\u001b[0m\r\n"]
[6.086, "o", "\r\n\r\n\r\n\u001b[1;36m▌ 1 · Loads beside the platform modules   \u001b[2mF1\u001b[0m\r\n\r\n\r\n"]
[3.009, "o", "\u001b[1;33m   start the LEZ chain, then the agent daemon\u001b[0m\r\n\r\n\r\n"]
[3.505, "o", "\u001b[1m   $ sequencer_service  lez-seq.json  -p 3040\u001b[0m\r\n"]
[10.529, "o", "\u001b[0;37m     block 1516\u001b[0m\r\n"]
[3.628, "o", "\u001b[0;37m     block 1517\u001b[0m\r\n"]
[3.616, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1m   $ logoscore -D -m ./modules   &&   logoscore load-module ...\u001b[0m\r\n"]
[10.951, "o", "     loaded capability_module\r\n     loaded storage_module\r\n     loaded lez_wallet_module\r\n     loaded chat_module\r\n     loaded delivery_module\r\n     loaded agent_module\r\n"]
[0.048, "o", "\r\n\u001b[1;32m   ✓ 6 modules, 0 crashed\u001b[0m\r\n"]
[3.509, "o", "\r\n\r\n\r\n\u001b[1;36m▌ 2 · One command to deploy   \u001b[2mF3\u001b[0m\r\n"]
[0.000, "o", "\r\n\r\n"]
[3.009, "o", "\u001b[1;33m   the boot above, wrapped into one CLI command\u001b[0m\r\n\r\n\r\n"]
[3.508, "o", "\u001b[1m   $ agent up  --owner <key>  --per-tx-limit 50\u001b[0m\r\n"]
[2.509, "o", "\u001b[0;37m     spawns the daemon, loads the modules, sets owner + limits\u001b[0m\r\n"]
[0.609, "o", "\r\n\u001b[1;32m   ✓ Deploy on any headless node in one line.\u001b[0m\r\n"]
[3.508, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 3 · Its own shielded account   \u001b[2mF2\u001b[0m\r\n\r\n\r\n"]
[3.008, "o", "\u001b[1;33m   its own balance, and the tasks it is tracking\u001b[0m\r\n\r\n\r\n"]
[3.508, "o", "\u001b[1m   $ logoscore call lez_wallet_module balance\u001b[0m\r\n"]
[2.570, "o", "     {\"method\":\"balance\",\"module\":\"lez_wallet_module\",\"result\":\"65\",\"status\":\"ok\"}\r\n"]
[0.001, "o", "\r\n"]
[0.001, "o", "\u001b[1m   $ logoscore call agent_module meta_status\u001b[0m\r\n"]
[2.562, "o", "     balance: 65 · active tasks: 38\r\n"]
[0.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Its own funds. It spends them itself, not the owner's wallet.\u001b[0m\r\n"]
[3.508, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 4 · Every skill, behind an open interface   \u001b[2mF6 · U1\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
[3.003, "o", "\u001b[1;33m   all capabilities, listed by the agent\u001b[0m\r\n\r\n\r\n"]
[3.508, "o", "\u001b[1m   $ logoscore call agent_module meta_skills\u001b[0m\r\n"]
[2.562, "o", "     21 skills:\r\n"]
[0.000, "o", "     storage.upload, storage.download, storage.list, storage.share, messaging.send, messaging.join, messaging.create_group, wallet.balance, wallet.send, wallet.history, program.query\r\n     program.call, program.deploy, agent.card, agent.discover, agent.task, agent.subscribe, agent.cancel, meta.skills, meta.status, meta.configure\r\n"]
[0.003, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Add more without forking the module (docs/SKILL_INTERFACE.md).\u001b[0m\r\n"]
[3.504, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 5 · An A2A-compatible card   \u001b[2mF7\u001b[0m\r\n\r\n\r\n"]
[3.008, "o", "\u001b[1;33m   how agents find each other, with the agent's keys attached\u001b[0m\r\n\r\n\r\n"]
[3.510, "o", "\u001b[1m   $ logoscore call agent_module agent_card\u001b[0m\r\n"]
[2.556, "o", "     {\r\n       \"name\": \"LP-0008 Autonomous Agent\",\r\n       \"capabilities\": {\r\n         \"extendedAgentCard\": true,\r\n         \"pushNotifications\": false,\r\n         \"streaming\": false\r\n       },\r\n       \"x-lez-identity\": \"<shielded keys>\"\r\n     }\r\n"]
[0.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ A2A schema plus shielded keys (docs/A2A_BINDING.md).\u001b[0m\r\n"]
[3.508, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 6 · An encrypted owner channel   \u001b[2mF4\u001b[0m\r\n\r\n\r\n"]
[3.008, "o", "\u001b[1;33m   the owner reaches the agent directly, no server\u001b[0m\r\n\r\n\r\n"]
[3.510, "o", "\u001b[1m   $ logoscore call agent_module messaging_send owner \"status?\"\u001b[0m\r\n"]
[2.557, "o", "     {\"method\":\"messaging_send\",\"module\":\"agent_module\",\"result\":\"{\\\"result\\\":{\\\"convo_id\\\":\\\"\\\",\\\"recipient\\\":\\\"owner-channel\\\",\\\"status\\\":\\\"sent\\\"}}\",\"status\":\"ok\"}\r\n"]
[0.002, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Reachable from any app holding the owner's keys.\u001b[0m\r\n"]
[3.503, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 7 · A real on-chain payment   \u001b[2muse case 1 · P1\u001b[0m\r\n\r\n"]
[0.000, "o", "\r\n"]
[3.010, "o", "\u001b[1;33m   a shielded transfer runs two proofs, watch the cycle counts\u001b[0m\r\n\r\n\r\n"]
[3.558, "o", "\u001b[1m   $ wallet auth-transfer send  --from <genesis>  --to-npk b13e9577cd2f…  --amount 7\u001b[0m\r\n"]
[2.575, "o", "     131072 total cycles\r\n     77565 user cycles (59.18%)\r\n"]
[15.204, "o", "     262144 total cycles\r\n     183970 user cycles (70.18%)\r\n"]
[73.601, "o", "     tx: 070360e8d9c88d05ea282082e2de501754a0cd5eb294aa15f16def8f16784843\r\n"]
[8.023, "o", "\u001b[0;37m     recipient: 0 → 7\u001b[0m\r\n"]
[0.607, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Settled on-chain, real proof. 393,216 cycles (docs/CU_COSTS.md).\u001b[0m\r\n"]
[3.509, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 8 · Spending limit — held above the cap   \u001b[2mF5 · R2\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
[3.010, "o", "\u001b[1;33m   limit is 50; try to spend 80, over the cap\u001b[0m\r\n\r\n\r\n"]
[3.509, "o", "\u001b[1m   $ logoscore call agent_module agent_task <card price=80> compute.run\u001b[0m\r\n"]
[4.666, "o", "     held: amount 80 · status: pending_approval\r\n     reason: spend exceeds autonomous threshold\r\n"]
[0.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Over the cap it is held, never auto-sent. Unreachable owner: retries, then reports.\u001b[0m\r\n"]
[3.508, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 9 · A private file vault   \u001b[2muse case 2 · F9\u001b[0m\r\n\r\n\r\n"]
[3.010, "o", "\u001b[1;33m   encrypt, store, get a content address, then read it back\u001b[0m\r\n\r\n\r\n"]
[6.645, "o", "\u001b[1m   $ logoscore call storage_module uploadInit / uploadChunk / uploadFinalize\u001b[0m\r\n"]
[5.134, "o", "\u001b[0;37m     CID  zDvZRwzkyy2RfSZiwxjvqUBP4E5u9urXaUnMu34WdKG8qt8vk9vN\u001b[0m\r\n"]
[0.608, "o", "\r\n"]
[0.000, "o", "\u001b[1m   $ logoscore call storage_module exists / downloadChunks  <CID>\u001b[0m\r\n"]
[2.610, "o", "\u001b[0;37m     exists: true    download: ok\u001b[0m\r\n"]
[0.604, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Stored and retrieved. No cloud provider.\u001b[0m\r\n"]
[3.510, "o", "\r\n\r\n\r\n\u001b[1;36m▌ 10 · Survives a restart   \u001b[2mR1\u001b[0m\r\n"]
[0.000, "o", "\r\n\r\n"]
[3.009, "o", "\u001b[1;33m   there are task records on disk; kill the daemon and restart\u001b[0m\r\n\r\n\r\n"]
[3.547, "o", "\u001b[0;37m     records before: 58\u001b[0m\r\n"]
[0.609, "o", "\r\n"]
[0.000, "o", "\u001b[1m   $ pkill -f 'logoscore -D'   &&   logoscore -D -m ./modules\u001b[0m\r\n"]
[2.562, "o", "tests/demo-full-a.sh: line 127: 79940 Killed: 9               RISC0_DEV_MODE=0 nohup \"$LC\" -D -m \"$M\" > \"$DLOG\" 2>&1\r\n"]
[12.338, "o", "\u001b[0;37m     records after restart: 58\u001b[0m\r\n"]
[0.608, "o", "\r\n\u001b[1;32m   ✓ Task state persisted. Nothing lost.\u001b[0m\r\n"]
[3.510, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 11 · A failing skill stays contained   \u001b[2mR3\u001b[0m\r\n\r\n\r\n"]
[3.009, "o", "\u001b[1;33m   call a skill with a bad input on purpose\u001b[0m\r\n\r\n\r\n"]
[3.510, "o", "\u001b[1m   $ logoscore call agent_module storage_download not-a-real-cid /tmp/x\u001b[0m\r\n"]
[2.565, "o", "     returned: error (isolated)\r\n"]
[0.051, "o", "\u001b[0;37m     module still loaded: yes\u001b[0m\r\n"]
[0.606, "o", "\r\n\u001b[1;32m   ✓ The skill failed, the module kept running.\u001b[0m\r\n"]
[3.508, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 12 · Deployed on testnet   \u001b[2mF10 · S1\u001b[0m\r\n\r\n\r\n"]
