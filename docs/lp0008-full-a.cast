[0.606, "o", "\u001b[0;37m     Messaging    — funded, addressable\u001b[0m\r\n"]
[0.608, "o", "\u001b[0;37m     Blockchain   — funded; sent + received, real proofs\u001b[0m\r\n"]
[0.606, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Reproduce steps + tx hashes in docs/TESTNET_EVIDENCE.md.\u001b[0m\r\n"]
