{"version":3,"term":{"cols":80,"rows":24},"timestamp":1781775479,"command":"bash tests/demo-full-a.sh < /dev/null","env":{"SHELL":"/bin/zsh"}}
[0.015, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m   LP-0008 — An autonomous AI agent that lives on Logos\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[2m   I am going to boot the real system live and run it, end to end.\u001b[0m\r\n"]
[0.306, "o", "\u001b[2m   Real zero-knowledge proofs throughout: RISC0_DEV_MODE=0, no mocks.\u001b[0m\r\n"]
[4.302, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 1 of 8 — Start the LEZ chain — a real sequencer, producing blocks\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.810, "o", "\u001b[0;36m   $ RISC0_DEV_MODE=0 sequencer_service  (real proofs)\u001b[0m\r\n"]
[1.010, "o", "\u001b[2m   Booting, then polling block height twice so you can see it advancing:\u001b[0m\r\n"]
[9.042, "o", "\u001b[2m     block height: 1154\u001b[0m\r\n"]
[3.028, "o", "\u001b[2m     block height: 1155\u001b[0m\r\n"]
[3.008, "o", "\r\n\u001b[1;32m   ✓ Live LEZ sequencer, real proofs, blocks advancing.\u001b[0m\r\n"]
[2.210, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 2 of 8 — Load the agent into Logos Core, beside the platform modules\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.807, "o", "\u001b[0;36m   $ RISC0_DEV_MODE=0 logoscore -D   then load the modules\u001b[0m\r\n"]
[9.457, "o", "\u001b[2m   These are the actual daemon log lines as each module comes up:\u001b[0m\r\n"]
[1.015, "o", "     loaded → capability_module\r\n     loaded → storage_module\r\n     loaded → lez_wallet_module\r\n     loaded → chat_module\r\n     loaded → delivery_module\r\n     loaded → agent_module\r\n"]
[1.010, "o", "\u001b[0;36m   $ logoscore status\u001b[0m\r\n"]
[1.061, "o", "      6 modules loaded, 0 crashed\r\n"]
[0.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Agent module live inside Logos Core — and it needed no changes to the others.\u001b[0m\r\n"]
[2.208, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 3 of 8 — The agent's skills and its A2A-compatible identity card\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.811, "o", "\u001b[0;36m   $ logoscore call agent_module meta_skills\u001b[0m\r\n"]
[1.063, "o", "     storage.upload, storage.download, storage.list, storage.share, messaging.send, messaging.join, messaging.create_group, wallet.balance, wallet.send, wallet.history, program.query\r\n     program.call, program.deploy, agent.card, agent.discover, agent.task, agent.subscribe, agent.cancel, meta.skills, meta.status, meta.configure\r\n"]
[1.510, "o", "\u001b[0;36m   $ logoscore call agent_module agent_card   (real output, trimmed)\u001b[0m\r\n"]
[1.059, "o", "     {\r\n       \"name\": \"LP-0008 Autonomous Agent\",\r\n       \"version\": \"0.0.1\",\r\n       \"capabilities\": {\r\n         \"extendedAgentCard\": true,\r\n         \"pushNotifications\": false,\r\n         \"streaming\": false\r\n       }\r\n     }\r\n     x-lez-identity present: True\r\n"]
[0.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ A2A-standard card, extended with the agent's shielded keys (x-lez).\u001b[0m\r\n"]
[2.209, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 4 of 8 — The agent's own shielded account\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.808, "o", "\u001b[0;36m   $ logoscore call lez_wallet_module balance   (raw response)\u001b[0m\r\n"]
[1.086, "o", "     {\"method\":\"balance\",\"module\":\"lez_wallet_module\",\"result\":\"85\",\"status\":\"ok\"}\r\n"]
[0.003, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Its own private balance. It spends this itself, not the owner's wallet.\u001b[0m\r\n"]
[2.206, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 5 of 8 — USE CASE 1 — a real on-chain payment, watch the prover run\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.803, "o", "\u001b[2m   A shielded transfer runs two zero-knowledge proofs. This is the live\u001b[0m\r\n"]
[2.205, "o", "\u001b[2m   RISC0 prover output. The cycle counts only exist with real proving:\u001b[0m\r\n"]
[1.051, "o", "\u001b[0;36m   $ RISC0_DEV_MODE=0 RISC0_INFO=1 wallet auth-transfer send  (~90s, live)\u001b[0m\r\n"]
[1.088, "o", "     \u001b[2m2026-06-18T09:38:59.448215Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m number of segments: 1\r\n     \u001b[2m2026-06-18T09:38:59.448227Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m 131072 total cycles\r\n"]
[0.000, "o", "     \u001b[2m2026-06-18T09:38:59.448232Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m 77790 user cycles (59.35%)\r\n     \u001b[2m2026-06-18T09:38:59.448235Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m 32256 paging cycles (24.61%)\r\n"]
[15.034, "o", "     \u001b[2m2026-06-18T09:39:14.482484Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m number of segments: 1\r\n     \u001b[2m2026-06-18T09:39:14.482486Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m 262144 total cycles\r\n     \u001b[2m2026-06-18T09:39:14.482490Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m 184195 user cycles (70.26%)\r\n     \u001b[2m2026-06-18T09:39:14.482508Z\u001b[0m \u001b[32m INFO\u001b[0m \u001b[2mrisc0_zkvm::host::server::session\u001b[0m\u001b[2m:\u001b[0m 68270 paging cycles (26.04%)\r\n"]
[68.712, "o", "     Transaction hash is b700e7639409eb1d1c756ca7ce030079ca0ef94c941191b8ae925325e6d366d1\r\n"]
[6.724, "o", "\r\n\u001b[1;32m   ✓ Recipient settled: 0 → 7. A private transfer, on-chain, real proof.\u001b[0m\r\n"]
[2.208, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 6 of 8 — Owner spending control\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.809, "o", "\u001b[2m   Owner sets a per-transaction limit. Below it the agent acts on its own;\u001b[0m\r\n"]
[2.210, "o", "\u001b[2m   above it the agent will not spend, it asks the owner first.\u001b[0m\r\n"]
[2.207, "o", "\u001b[1;33m     per-transaction limit = 50 LEZ\u001b[0m\r\n"]
[1.009, "o", "     ≤ 50 → autonomous      > 50 → held for owner approval\r\n"]
[1.509, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Autonomy with a hard guardrail the owner sets.\u001b[0m\r\n"]
[2.210, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  STEP 7 of 8 — USE CASE 2 — a private file vault, full round trip (live)\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[4.956, "o", "\u001b[0;36m   $ storage_module peerId   (the local storage node, live)\u001b[0m\r\n"]
[5.023, "o", "      16Uiu2HAmF3eaxFHPKYpWLvi6xyTwdxnjoJRfhsXwz8KPgDJNa7F4\r\n"]
[0.007, "o", "\u001b[0;36m   $ uploadInit -> uploadChunk -> uploadFinalize\u001b[0m\r\n"]
[1.170, "o", "\u001b[2m     content address (CID): zDvZRwzkyy2RfSZiwxjvqUBP4E5u9urXaUnMu34WdKG8qt8vk9vN\u001b[0m\r\n"]
[1.508, "o", "\u001b[0;36m   $ exists(zDvZRwzkyy2RfSZiwxjvqUBP4E5u9urXaUnMu34WdKG8qt8vk9vN)  +  downloadChunks(...)\u001b[0m\r\n"]
[1.054, "o", "     exists:   {\"method\":\"exists\",\"module\":\"storage_module\",\"result\":{\"error\":null,\"success\":true,\"value\":true},\"status\":\"ok\"}\r\n"]
[0.048, "o", "     download: \"success\":true\r\n"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Encrypt → store → content address → retrieve. No cloud in the middle.\u001b[0m\r\n"]
[2.208, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.001, "o", "\u001b[1;34m  STEP 8 of 8 — Owner messaging + deployed on the hosted testnet\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.810, "o", "\u001b[0;36m   $ logoscore call agent_module messaging_send <owner channel>\u001b[0m\r\n"]
[1.073, "o", "     {\"method\":\"messaging_send\",\"module\":\"agent_module\",\"result\":\"{\\\"result\\\":{\\\"convo_id\\\":\\\"\\\",\\\"recipient\\\":\\\"owner-channel\\\",\\\"status\\\":\\\"sent\\\"}}\",\"status\":\"ok\"}\r\n"]
[0.003, "o", "\u001b[2m   And on the hosted testnet I deployed three agents, one per skill category\u001b[0m\r\n"]
[2.209, "o", "\u001b[2m   (storage, messaging, blockchain), each funded with real proofs.\u001b[0m\r\n"]
[2.211, "o", "\u001b[2m   Reproduce steps + tx hashes: docs/TESTNET_EVIDENCE.md\u001b[0m\r\n"]
[1.509, "o", "\r\n\u001b[1;32m   ✓ Encrypted owner channel, no server; and it runs on the real testnet.\u001b[0m\r\n"]
[2.208, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1;34m────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
