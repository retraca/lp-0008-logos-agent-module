[0.000, "o", "\u001b[1m   LP-0008 — an autonomous AI agent on Logos\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[2m   every command is real and runs live · RISC0_DEV_MODE=0\u001b[0m\r\n"]
[6.096, "o", "\r\n\r\n\r\n\u001b[1;36m▌ 1 · Loads beside the platform modules   \u001b[2mF1\u001b[0m\r\n\r\n\r\n"]
[2.207, "o", "\u001b[1;33m   start the LEZ chain, then the agent daemon\u001b[0m\r\n\r\n"]
[2.606, "o", "   \u001b[1;32m\u001b[1m$\u001b[0m \u001b[1msequencer_service  lez-seq.json  -p 3040\u001b[0m\r\n"]
[9.838, "o", "\u001b[2m       block 1563\u001b[0m\r\n"]
[3.442, "o", "\u001b[2m       block 1564\u001b[0m\r\n"]
[3.413, "o", "\r\n\r\n"]
[0.000, "o", "   \u001b[1;32m\u001b[1m$\u001b[0m \u001b[1mlogoscore -D -m ./modules   &&   logoscore load-module ...\u001b[0m\r\n"]
[10.248, "o", "     loaded capability_module\r\n     loaded storage_module\r\n     loaded lez_wallet_module\r\n     loaded chat_module\r\n     loaded delivery_module\r\n     loaded agent_module\r\n"]
[0.055, "o", "\r\n\u001b[1;32m   ✓ 6 modules, 0 crashed\u001b[0m\r\n"]
[2.609, "o", "\r\n\r\n\r\n"]
[0.000, "o", "\u001b[1;36m▌ 2 · One command to deploy   \u001b[2mF3\u001b[0m\r\n\r\n\r\n"]
[2.204, "o", "\u001b[1;33m   the boot above, wrapped into one CLI command\u001b[0m\r\n\r\n"]
[2.607, "o", "   \u001b[1;32m\u001b[1m$\u001b[0m \u001b[1magent up  --owner <key>  --per-tx-limit 50\u001b[0m\r\n"]
[1.809, "o", "\u001b[2m       spawns the daemon, loads the modules, sets owner + limits\u001b[0m\r\n"]
[0.409, "o", "\r\n\u001b[1;32m   ✓ Deploy on any headless node in one line.\u001b[0m\r\n"]
[2.606, "o", "\r\n\r\n\r\n\u001b[1;36m▌ 3 · Its own shielded account   \u001b[2mF2\u001b[0m\r\n\r\n\r\n"]
[2.210, "o", "\u001b[1;33m   its own balance, and the tasks it is tracking\u001b[0m\r\n\r\n"]
[2.603, "o", "   \u001b[1;32m\u001b[1m$\u001b[0m \u001b[1mlogoscore call lez_wallet_module balance\u001b[0m\r\n"]
[1.872, "o", "     {\"method\":\"balance\",\"module\":\"lez_wallet_module\",\"result\":\"60\",\"status\":\"ok\"}\r\n"]
[0.002, "o", "\r\n"]
[0.000, "o", "   \u001b[1;32m\u001b[1m$\u001b[0m \u001b[1mlogoscore call agent_module meta_status\u001b[0m\r\n"]
[1.863, "o", "     balance: 60 · active tasks: 40\r\n"]
[0.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;32m   ✓ Its own funds. It spends them itself, not the owner's wallet.\u001b[0m\r\n"]
[2.607, "o", "\r\n\r\n\r\n"]
