[0.000, "o", "   (RISC0_DEV_MODE=0 → real zero-knowledge proofs)\r\n"]
[1.008, "o", "\r\n\u001b[1;34m══════════════════════════════════════════════════════════════\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34m  1. MODULE LOADS inside Logos Core, alongside wallet/storage/messaging (F1)\u001b[0m\r\n"]
