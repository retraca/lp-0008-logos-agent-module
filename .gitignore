# Build outputs — never commit compiled artefacts
scaffold/build/
**/target/
**/result/
**/result-*/

# Compiled plugin binaries (built from source; regenerated by `nix build`)
*.so
*.dylib

# Compiled programs / raw binaries
*.bin

# Video and animation files — keep repo clone fast
*.mp4
*.avi
*.mov
*.mkv
*.gif
# asciinema .cast files are plain text and intentionally committed

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Nix
.direnv/
result
result-*

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
build.ninja
.ninja_deps
.ninja_log

# Environment / secrets
.env
.env.local
*.key
*.pem
runtime-modules/
**/build/
